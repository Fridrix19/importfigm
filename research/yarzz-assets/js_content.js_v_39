(function enrichCaseVisualInfo(content) {
  const cases = Array.isArray(content?.cases) ? content.cases : [];

  function clean(value) {
    return String(value ?? "").trim();
  }

  function normalize(value) {
    return clean(value).toLowerCase();
  }

  function hasExplicitInfo(item) {
    return Boolean(clean(item?.info) || clean(item?.info_text) || clean(item?.description));
  }

  function firstText(...values) {
    return values.map(clean).find(Boolean) || "";
  }

  function describeSlide(slug, title, alt, caseName) {
    const text = normalize(`${title} ${alt}`);
    const label = firstText(title, alt);
    const visibleLabel = /^visual\s+\d+$/i.test(label) ? "" : label;
    const name = firstText(caseName, slug, "кейса");

    if (slug === "contentbook-client-govorit") {
      if (text.includes("главная")) return "Старт контентбука: коротко о задаче, тоне и том, как дальше устроен материал.";
      if (text.includes("стратег")) return "Стратегический блок: позиционирование, ключевые смыслы и рамка для всех следующих разделов.";
      if (text.includes("визуаль")) return "Визуальный язык: акценты, принципы оформления и примеры для разных носителей.";
      if (text.includes("канал")) return "Адаптация по каналам: одна идея раскладывается на площадки без потери узнаваемости.";
      if (text.includes("процесс")) return "Процесс работы: входные материалы, этапы и точки согласования.";
      if (text.includes("дополн")) return "Дополнительные правила: мелочи, которые помогают системе не расползаться после запуска.";
    }

    if (slug === "booktune") {
      if (text.includes("главная")) return "Витрина магазина: подборки, навигация и быстрый вход в покупку.";
      if (text.includes("каталог")) return "Каталог с карточками и категориями, чтобы книги было легко сравнивать между собой.";
      if (text.includes("товар")) return "Карточка книги: обложка, описание, цена и главное действие рядом.";
      if (text.includes("корз")) return "Корзина перед оформлением: состав заказа, сумма и спокойный следующий шаг.";
      if (text.includes("компон")) return "Компоненты магазина: кнопки, карточки и повторяемые элементы в одном стиле.";
    }

    if (slug === "mesto-cultural-space") {
      if (text.includes("главная")) return "Главная держит атмосферу места и сразу ведёт к событиям.";
      if (text.includes("афиша")) return "Афиша строится вокруг крупного визуала, даты и быстрого входа в детали события.";
      if (text.includes("сетк")) return "Сетка и компоненты: отступы, повторяемые блоки и правила сборки интерфейса.";
      if (text.includes("колон")) return "Колонки задают каркас, на котором страницы не разваливаются при масштабировании.";
      if (text.includes("кноп")) return "Кнопки с состояниями и отступами, чтобы интерактивные элементы выглядели едино.";
      if (text.includes("пол")) return "Поля ввода: размеры, форма и расстояния внутри общей системы.";
      if (text.includes("меню")) return "Верхнее меню: основной маршрут между разделами площадки.";
      if (text.includes("спецификац")) return "Спецификация для передачи в разработку: размеры, состояния и поведение компонентов.";
    }

    if (slug === "ethical-dilemma-hackathon") {
      if (text.includes("меню")) return "Главное меню сразу задаёт тему, настроение и точку старта игры.";
      if (text.includes("инструк")) return "Инструкции объясняют правила до начала игры: какие решения нужно принимать и какие показатели будут меняться.";
      if (text.includes("выбор")) return "Сцена выбора: ситуация, варианты ответа и ощущение, что решение правда что-то меняет.";
      if (text.includes("решен")) return "Результат выбора с изменением игровых параметров и коротким объяснением последствий.";
      if (text.includes("поражен")) return "Экран поражения закрывает неудачную ветку и делает последствия решений заметными, а не абстрактными.";
    }

    if (slug === "aurora-todoapp") {
      if (text.includes("глав")) return "Главный экран: список задач и быстрый вход в управление ими.";
      if (text.includes("детал")) return "Детали задачи с редактированием и дополнительной информацией.";
      if (text.includes("трет")) return "Дополнительный экран расширяет структуру за пределы основного списка.";
      if (text.includes("спецификац")) return "Спецификация фиксирует визуальные и технические параметры интерфейса под Аврора ОС.";
      if (text.includes("структур")) return "Структура проекта: QML-экраны, ресурсы и сборочные файлы в одной схеме.";
    }

    if (slug === "pharmacy-mobile-app") {
      if (text.includes("глав")) return "Главная: поиск, промо и категории на первом экране. До товара можно добраться без лишних шагов.";
      if (text.includes("каталог")) return "Каталог аптеки: карточки, разделы и фильтры для быстрого поиска нужной позиции.";
      if (text.includes("карточ")) return "Карточка товара: цена, описание и кнопка покупки держатся рядом, без визуального шума.";
      if (text.includes("пуст")) return "Пустая корзина не выглядит тупиком: есть понятный возврат к товарам.";
      if (text.includes("корз")) return "Корзина с составом заказа, итоговой суммой и переходом к оформлению.";
      if (text.includes("оформ")) return "Оформление заказа: адрес, доставка и подтверждение собраны в один спокойный маршрут.";
      if (text.includes("проф")) return "Профиль с личными данными, бонусами и быстрым доступом к заказам.";
      if (text.includes("истор")) return "История заказов: удобно проверить прошлые покупки или повторить заказ.";
      if (text.includes("адрес")) return "Выбор адреса доставки без лишней формы и с понятным подтверждением.";
      if (text.includes("тем")) return "Тёмная тема: те же акценты и читаемость, но в другой палитре.";
    }

    if (slug === "loopi-video-app") {
      if (text.includes("добро")) return "Первый экран онбординга задаёт дружелюбный тон приложения и снижает порог входа.";
      if (text.includes("контент")) return "Экран про просмотр: что можно открыть, изучить и сохранить внутри приложения.";
      if (text.includes("созда")) return "Создание контента как вторая половина продукта: не только смотреть, но и публиковать своё.";
      if (text.includes("сообще")) return "Экран сообщества объясняет социальный слой приложения: реакции, связь с авторами и взаимодействие вокруг видео.";
      if (text.includes("начни")) return "Финальный экран онбординга переводит пользователя от объяснения ценности к началу работы с приложением.";
      if (text.includes("прилож")) return "Основной экран после онбординга: уже не обещание, а реальный интерфейс просмотра.";
    }

    if (slug === "brief-generator") {
      if (text.includes("глав")) return "Главный экран генератора ТЗ: выбор формата и быстрый старт работы.";
      if (text.includes("диалог")) return "Диалоговый режим для сбора требований без жёсткой формы.";
      if (text.includes("шаблон")) return "Формат шаблона подходит для структурированного ввода: поля помогают не забыть важные параметры проекта.";
      if (text.includes("endpoint") || text.includes("api")) return "Endpoint-схема: запрос уходит в AI-часть и возвращается обратно в интерфейс.";
    }

    if (slug === "sticker-peel") {
      if (text.includes("глав") || text.includes("landing")) return "Стартовая страница Sticker Peel: название сервиса, краткое объяснение инструмента, загрузка SVG и кнопка для перехода к пробному сценарию.";
      if (text.includes("одним") || text.includes("basic")) return "Базовый редактор: экран настройки одного загиба с параметрами, предпросмотром и скачиванием готового SVG.";
      if (text.includes("несколько") || text.includes("advanced")) return "Расширенный редактор: экран для нескольких загибов, бликов и более детальной настройки эффекта.";
      if (text.includes("мобильный вход")) return "Мобильный старт: описание инструмента, загрузка SVG и переход к пробе.";
      if (text.includes("мобильный редактор")) return "Мобильный редактор: настройка загиба и предпросмотр в узком экране.";
      if (text.includes("мобиль")) return "Мобильная адаптация одного из сценариев Sticker Peel.";
    }

    if (slug === "hideself") {
      if (text.includes("глав")) return "Главная с состоянием подключения и ключевыми показателями защиты.";
      if (text.includes("траф")) return "Статистика трафика помогает оценить текущую сессию и увидеть динамику соединения.";
      if (text.includes("сесс")) return "Детали сессии раскрывают технические параметры подключения: core, режимы и адреса.";
      if (text.includes("импорт")) return "Импорт профилей: добавление подписок и отдельных конфигураций.";
      if (text.includes("список")) return "Список профилей нужен для выбора сервера, проверки задержки и быстрых действий с конфигурациями.";
      if (text.includes("домен")) return "Маршруты доменов показывают split routing: какие сайты идут через выбранные правила.";
      if (text.includes("прилож")) return "Маршруты приложений позволяют управлять трафиком на уровне Windows-приложений.";
      if (text.includes("zapret")) return "Раздел Zapret: пресеты обхода ограничений и состояние сервиса.";
      if (text.includes("tg")) return "TG WS: отдельный прокси для Telegram и связанные настройки.";
      if (text.includes("live")) return "Live-подключения показывают активные сетевые соединения в реальном времени.";
      if (text.includes("подключ")) return "Детали подключения раскрывают выбранную строку таблицы без ухода со страницы.";
      if (text.includes("логи")) return "Логи нужны для диагностики: они показывают, что происходит внутри клиента при ошибках или смене состояний.";
      if (text.includes("настрой")) return "Настройки собирают системные параметры клиента: core, TUN, failover и поведение интерфейса.";
    }

    if (slug === "eat-landing") {
      if (text.includes("desktop")) return "Полный desktop-скрин лендинга: крупная типографика, мокапы и длинная промо-структура.";
      if (text.includes("мобиль")) return "Мобильная версия: порядок блоков, читаемость и тот же яркий характер на узком экране.";
    }

    if (slug === "pik-tracker") {
      if (text.includes("стрик")) return "Стрик и прогресс за день: быстрый статус без лишних деталей.";
      if (text.includes("трениров")) return "Экран тренировки: быстро добавить подходы и сразу видеть текущий прогресс.";
      if (text.includes("выполн")) return "Состояние выполненного упражнения фиксирует завершение действия и подкрепляет ощущение прогресса.";
      if (text.includes("все")) return "Список всех упражнений на день и быстрый переход к незакрытым пунктам.";
      if (text.includes("кален")) return "Календарь и сравнение: динамика по дням плюс тренировки для двоих.";
      if (text.includes("целей")) return "Настройки целей позволяют подстроить дневную норму без изменения всей логики приложения.";
      if (text.includes("напомин")) return "Напоминания помогают вернуть пользователя к тренировке в нужное время.";
      if (text.includes("врем")) return "Выбор времени для push-напоминаний.";
      if (text.includes("push")) return "Push-уведомление срабатывает вне открытой страницы и возвращает к тренировке.";
    }

    if (slug === "hackathon-ai-assistant") {
      if (text.includes("меню")) return "Главное меню ассистента: выбор формата тренировки перед стартом.";
      if (text.includes("ии")) return "Настройка дебатов с ИИ задаёт роль оппонента, сложность и рамки будущего диалога.";
      if (text.includes("студент")) return "Настройка дебатов со студентом как второй формат тренировки аргументации.";
      if (text.includes("защита")) return "Сценарий защиты диплома собирает параметры комиссии и формат вопросов перед началом сессии.";
      if (text.includes("диалог")) return "Диалоговый тренажёр: вопрос, ответ и развитие контраргументов.";
      if (text.includes("workflow")) return "Workflow со связкой frontend, AI-логики и оркестрации запросов.";
    }

    if (visibleLabel) {
      return `Кадр «${visibleLabel}» из кейса «${name}». Короткая подпись к тому, что важно рассмотреть на этом экране.`;
    }

    return `Дополнительный визуал из кейса «${name}»: короткая заметка к экрану без отдельной подписи.`;
  }

  cases.forEach((item) => {
    const visuals = Array.isArray(item?.visuals) ? item.visuals : [];
    visuals.forEach((visual) => {
      if (visual?.type === "section") return;

      if (clean(visual.caption)) {
        delete visual.info;
      } else if (!hasExplicitInfo(visual) && !Array.isArray(visual.slides)) {
        visual.info = describeSlide(item.slug, visual.title, visual.alt, item.name);
      }

      if (Array.isArray(visual.slides)) {
        visual.slides.forEach((slide) => {
          if (!hasExplicitInfo(slide)) {
            const info = describeSlide(item.slug, slide.title, slide.alt, item.name);
            if (info) slide.info = info;
          }
        });
      }
    });
  });
})(window.portfolioContent);
